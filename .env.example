# Copy to .env and override only what you need.

# API endpoint used for shortlist upserts.
JOB_SEARCH_API_BASE_URL=http://127.0.0.1:8000

# Optional API key sent during upserts when backend requires write access.
JOB_SEARCH_WRITE_API_KEY=

# Optional override for package defaults JSON.
# Example: /absolute/path/to/discovery_config.override.json
DISCOVERY_CONFIG_PATH=

# Optional LLM provider settings (used only when --use-llm-reranker is enabled).
OPENAI_API_KEY=
LLM_API_KEY=
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
